# n8n VPS environment — copy to /opt/n8n/.env and fill in values

# n8n
N8N_HOST=n8n.yourdomain.com         # subdomain pointing to your VPS IP
N8N_BASIC_AUTH_USER=julio
N8N_BASIC_AUTH_PASSWORD=changeme     # strong password

# Postgres
POSTGRES_PASSWORD=changeme_strong

# Telegram
TELEGRAM_BOT_TOKEN=                  # from @BotFather
TELEGRAM_CHAT_ID=                    # your personal chat ID (send a msg, check n8n execution log)

# GitHub
GITHUB_TOKEN=                        # github_pat_... with repo write scope

# Anthropic
ANTHROPIC_API_KEY=                   # sk-ant-...

# Gmail
GMAIL_USERNAME=juliokoelle@gmail.com
GMAIL_APP_PASSWORD=                  # 16-char app password from Google Account
